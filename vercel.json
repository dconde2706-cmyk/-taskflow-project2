{
  "version": 2,
  "builds": [
    { "src": "server/src/index.js", "use": "@vercel/node" },
    { "src": "client/**", "use": "@vercel/static" }
  ],
  "routes": [
    { 
      "src": "/api/v1/tasks(.*)", 
      "dest": "server/src/index.js" 
    },
    { 
      "src": "/(.*)", 
      "dest": "client/$1" 
    }
  ]
}
